%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: de640fe3d0db1804a85f9fc8f5cadab7, type: 3}
  m_Name: AerospinForwardRenderer
  m_EditorClassIdentifier:
  m_RendererFeatures:
  # ---- Screen-Space Ambient Occlusion ----
  - rid: 1
  m_RendererFeatureMap:
    1:
      m_FeatureName: ScreenSpaceAmbientOcclusion
      m_IsActive: 1
      settings:
        Intensity: 0.8
        Radius: 0.035
        DirectLightingStrength: 0.25
        BlurQuality: 3            # 0=Low … 3=High
        Downsample: 0
        AfterOpaque: 0
  # ---- Screen-Space Reflections ----
  - rid: 2
  m_RendererFeatureMap:
    2:
      m_FeatureName: ScreenSpaceReflections
      m_IsActive: 1
      settings:
        ReflectSky: 1
        Quality: 1                # 0=Low 1=Medium 2=High
        RayMinStep: 0.02
        MaxDistance: 25.0
        RayMaxSteps: 64
        Thickness: 0.5
  # ---- Full-Screen Chromatic Aberration Pass ----
  - rid: 3
  m_RendererFeatureMap:
    3:
      m_FeatureName: FullScreenPassRendererFeature
      m_IsActive: 1
      settings:
        PassMaterial: {fileID: 2100000, guid: aerospin_chromatic_aberration_mat, type: 2}
        InjectionPoint: 3         # 3 = AfterRenderingPostProcessing
  # ---- Lens Flares ----
  - rid: 4
  m_RendererFeatureMap:
    4:
      m_FeatureName: LensFlareDataDrivenFeature
      m_IsActive: 1
  m_UseNativeRenderPass: 1        # Vulkan / Metal Tile-Based Deferred shading
  m_RenderingMode: 0              # 0 = Forward+
  m_DepthPrimingMode: 2           # 2 = Auto
  m_CopyDepthMode: 0
  m_AccurateGbufferNormals: 1
